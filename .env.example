# EIA (US Energy Information Administration) — free Brent crude spot price feed.
# Register at https://www.eia.gov/opendata/register.php (no credit card, instant)
#
# Vite inlines this at BUILD time, not runtime, so it must be set when you run
# `npm run build`. Without it, the app shows a hardcoded fallback price.
VITE_EIA_API_KEY=
